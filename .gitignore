# ---- Unity 생성 폴더 (버전관리 제외) ----
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data (폴더 안이 비어 있으면 meta 제외)
!/[Aa]ssets/**/*.meta

# Visual Studio / Rider / IDE
.vs/
.vscode/
.idea/
*.csproj
*.sln
*.slnx
*.user
*.userprefs
*.suo
*.tmp
*.unityproj
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db
desktop.ini

# Unity 크래시/빌드 부산물
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties
